{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(py -3.14*)",
      "Bash(pip*)",
      "Bash(uvicorn*)",
      "Bash(python*)",
      "Bash(cat*)",
      "Bash(ls*)",
      "Bash(dir*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(curl*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(del /s *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(format*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "write",
        "hooks": [
          {
            "type": "command",
            "command": "echo Post-write check complete"
          }
        ]
      }
    ],
    "PreCommit": [
      {
        "type": "command",
        "command": "py -3.14 -c \"import ast, sys; [ast.parse(open(f).read()) for f in sys.argv[1:] if f.endswith('.py')]\""
      }
    ]
  },
  "env": {
    "PYTHON_CMD": "py -3.14",
    "UVICORN_HOST": "127.0.0.1",
    "UVICORN_PORT": "8765",
    "PE_DASHBOARD_ROOT": "C:\\Users\\1039081\\Downloads\\PE_Dashboard"
  }
}
